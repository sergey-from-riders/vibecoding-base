# apps/web environment template

# React dev/runtime
NODE_ENV=development
PORT=18030
HOSTNAME=0.0.0.0

# Public API (browser)
VITE_APP_API_BASE_URL=http://localhost:18031
VITE_APP_BASE_URL=http://localhost:18030

# Telegram Mini App mode
VITE_APP_TELEGRAM_ENABLED=true
VITE_APP_TELEGRAM_BOT_USERNAME=

# Internal server-side API (optional override)
APP_WEB_INTERNAL_API_BASE_URL=http://127.0.0.1:18031
