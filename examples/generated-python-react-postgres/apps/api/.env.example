# apps/api environment template

# Server
APP_API_HOST=0.0.0.0
APP_API_PORT=18031
APP_API_READ_TIMEOUT=10s
APP_API_WRITE_TIMEOUT=10s
APP_API_IDLE_TIMEOUT=120s

# App
APP_ENV=development
APP_LOG_LEVEL=info
APP_ALLOWED_ORIGINS=http://localhost:18030
APP_PROBLEM_BASE_URL=https://api.localhost/problems

# Database (PostgreSQL)
APP_DB_HOST=127.0.0.1
APP_DB_PORT=5432
APP_DB_NAME=ai_app
APP_DB_USER=ai_app
APP_DB_PASSWORD=local_dev_password_only
APP_DB_SSLMODE=disable
APP_DB_MAX_OPEN_CONNS=25
APP_DB_MAX_IDLE_CONNS=5
APP_DB_CONN_MAX_LIFETIME=5m

# Auth
APP_AUTH_SESSION_TTL=720h
APP_AUTH_BCRYPT_COST=12
APP_AUTH_ACTIVATION_TOKEN_TTL=24h
APP_AUTH_RESET_TOKEN_TTL=1h

# CORS and proxy headers
APP_TRUST_PROXY=true
APP_REAL_IP_HEADER=X-Real-IP

# Telegram Mini App validation (if enabled)
APP_TELEGRAM_BOT_TOKEN=
