{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "generated project vibe profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stack",
    "project_name",
    "registry_version",
    "components",
    "enabled",
    "disabled"
  ],
  "properties": {
    "stack": { "type": "string" },
    "project_name": { "type": "string" },
    "registry_version": { "type": "string" },
    "components": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "enabled": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "disabled": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    }
  }
}
