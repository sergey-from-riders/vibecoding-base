{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vibecoding-base standard",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "status",
    "domain",
    "owners",
    "applies_to",
    "dependencies",
    "enforcement",
    "files",
    "compatibility",
    "changelog"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$" },
    "name": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "status": { "enum": ["draft", "experimental", "stable", "deprecated"] },
    "domain": { "type": "string" },
    "owners": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "applies_to": { "type": "object" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "enforcement": {
      "type": "object",
      "required": ["documented", "linted", "tested", "ci_blocking"],
      "properties": {
        "documented": { "type": "boolean" },
        "linted": { "type": "boolean" },
        "tested": { "type": "boolean" },
        "ci_blocking": { "type": "boolean" }
      }
    },
    "files": { "type": "object" },
    "compatibility": { "type": "object" },
    "changelog": { "type": "string" }
  }
}
