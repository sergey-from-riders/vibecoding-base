{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vibecoding-base stack profile",
  "type": "object",
  "required": [
    "id",
    "name",
    "status",
    "description",
    "components",
    "standards",
    "templates",
    "checks",
    "readiness"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "status": { "enum": ["draft", "experimental", "stable", "deprecated"] },
    "components": { "type": "object" },
    "standards": { "type": "array", "items": { "type": "string" } },
    "templates": { "type": "array", "items": { "type": "string" } },
    "checks": { "type": "array", "items": { "type": "string" } },
    "readiness": {
      "type": "object",
      "required": ["template", "runtime", "checks", "docs"],
      "properties": {
        "template": { "enum": ["ready", "partial", "missing"] },
        "runtime": { "enum": ["ready", "partial", "missing"] },
        "checks": { "enum": ["ready", "partial", "missing"] },
        "docs": { "enum": ["ready", "partial", "missing"] }
      }
    }
  }
}
