# apps/web environment template

# Next runtime
NODE_ENV=development
PORT=18030
HOSTNAME=0.0.0.0

# Public API (browser)
NEXT_PUBLIC_APP_API_BASE_URL=http://localhost:18031
NEXT_PUBLIC_APP_BASE_URL=http://localhost:18030

# Telegram Mini App mode
NEXT_PUBLIC_APP_TELEGRAM_ENABLED=true
NEXT_PUBLIC_APP_TELEGRAM_BOT_USERNAME=

# Internal server-side API (optional override)
APP_WEB_INTERNAL_API_BASE_URL=http://127.0.0.1:18031
