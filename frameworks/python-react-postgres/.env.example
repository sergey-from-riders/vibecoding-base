# Python React Postgres Framework global environment template

# Environment
APP_ENV=development
APP_NAME=ai-app
APP_BASE_DOMAIN=localhost

# Public entrypoint (Nginx)
APP_PUBLIC_SCHEME=http
APP_PUBLIC_HOST=localhost

# Internal app ports on server (host side)
APP_WEB_PORT=18030
APP_API_PORT=18031

# Observability
APP_LOG_LEVEL=info
APP_REQUEST_ID_HEADER=X-Request-Id
