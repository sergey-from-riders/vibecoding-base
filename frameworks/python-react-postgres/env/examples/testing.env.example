# CI/E2E testing environment template (non-production only)

# Universal regression account (test/stage only)
APP_E2E_UNIVERSAL_EMAIL=qa.universal@example.test
APP_E2E_UNIVERSAL_PASSWORD=REPLACE_IN_SECRET_MANAGER

# Optional provider test identities (if enabled in environment)
APP_E2E_UNIVERSAL_TELEGRAM_ID=
APP_E2E_UNIVERSAL_GOOGLE_SUB=
APP_E2E_UNIVERSAL_YANDEX_SUB=
APP_E2E_UNIVERSAL_VK_SUB=

# Test target
APP_E2E_BASE_URL=https://staging.example.test
APP_E2E_API_BASE_URL=https://staging.example.test/api
