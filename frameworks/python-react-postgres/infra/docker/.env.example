# Server deployment environment for docker compose

# Container images
APP_API_IMAGE=ghcr.io/your-org/ai-app-api:REPLACE_WITH_COMMIT_SHA
APP_WEB_IMAGE=ghcr.io/your-org/ai-app-web:REPLACE_WITH_COMMIT_SHA

# Published host ports (Nginx proxies to these)
APP_API_PORT=18031
APP_WEB_PORT=18030

# Network
APP_DOCKER_NETWORK=ai-app-net

# API runtime values passed to container
APP_ENV=production
APP_LOG_LEVEL=info
APP_ALLOWED_ORIGINS=https://app.example.test
APP_PROBLEM_BASE_URL=https://app.example.test/problems

# Database connection for API container
APP_DB_HOST=postgres
APP_DB_PORT=5432
APP_DB_NAME=ai_app
APP_DB_USER=ai_app
APP_DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
APP_DB_SSLMODE=disable

# Telegram bot token if Mini App signature validation is used
APP_TELEGRAM_BOT_TOKEN=
