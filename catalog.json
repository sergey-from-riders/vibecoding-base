{
  "name": "vibecoding-base",
  "version": "1.1.0",
  "description": "Composable stack profiles and standards registry for AI-native development.",
  "registry": {
    "path": "registry",
    "standards": "registry/standards",
    "stacks": "registry/stacks",
    "templates": "registry/templates",
    "checks": "registry/checks",
    "schemas": "registry/schemas"
  },
  "stacks": [
    {
      "id": "go-next-postgres",
      "name": "Go + Next.js + PostgreSQL",
      "profile": "registry/stacks/go-next-postgres.yaml",
      "example": "examples/generated-go-next-postgres",
      "status": "stable",
      "readiness": {
        "template": "ready",
        "runtime": "partial",
        "checks": "partial",
        "docs": "ready"
      }
    },
    {
      "id": "python-react-postgres",
      "name": "Python/FastAPI + React + PostgreSQL",
      "profile": "registry/stacks/python-react-postgres.yaml",
      "example": "examples/generated-python-react-postgres",
      "status": "stable",
      "readiness": {
        "template": "ready",
        "runtime": "partial",
        "checks": "partial",
        "docs": "ready"
      }
    }
  ]
}
